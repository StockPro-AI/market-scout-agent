# ============================================================
# Market Scout Agent - Konfiguration
# ============================================================
# Kopiere diese Datei: cp .env.example .env
# Trage deine API Keys ein. Mindestens eine Datenquelle benoetigt.

# ------------------------------------------------------------
# DATENQUELLEN (mindestens eine benoetigt)
# ------------------------------------------------------------

# Finnhub API Key (https://finnhub.io)
FINNHUB_API_KEY=

# Alpha Vantage API Key (https://www.alphavantage.co)
ALPHA_VANTAGE_API_KEY=

# ------------------------------------------------------------
# LLM PROVIDER (einer benoetigt)
# ------------------------------------------------------------

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Anthropic Claude
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# Google Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-pro

# Aktiver LLM Provider: openai | anthropic | gemini
LLM_PROVIDER=openai

# ------------------------------------------------------------
# WATCHLIST
# ------------------------------------------------------------
# Kommagetrennte Liste von Symbolen
WATCHLIST=AAPL,TSLA,NVDA,MSFT,AMZN,META,GOOGL,AMD,SPY,QQQ

# ------------------------------------------------------------
# SCANNER EINSTELLUNGEN
# ------------------------------------------------------------

# Mindest-RVOL (Relative Volume) fuer Kandidaten
MIN_RVOL=1.5

# Mindest-Preisaenderung in % fuer Kandidaten
MIN_PRICE_CHANGE_PCT=0.5

# Maximale Anzahl Opportunity Cards pro Tag
MAX_DAILY_CARDS=3

# ------------------------------------------------------------
# ZEITFENSTER (NYSE Eastern Time)
# ------------------------------------------------------------

# Morgensession: Stunden nach Market Open scannen
MORNING_SESSION_HOURS=2.5

# Abendsession: Minuten vor Market Close scannen
EVENING_SESSION_MINUTES=90

# ------------------------------------------------------------
# OUTPUT
# ------------------------------------------------------------

# Terminal-Dashboard aktivieren: true | false
ENABLE_TERMINAL_DASHBOARD=true

# Telegram Bot (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
ENABLE_TELEGRAM=false

# SQLite Log Datei
DB_PATH=data/signals.db

# Log Level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# ------------------------------------------------------------
# RISK CHECKER
# ------------------------------------------------------------

# Mindest Risk/Reward Ratio
MIN_RISK_REWARD=2.0

# Mindest-Liquiditaet (durchschnittliches Tagesvolumen in USD)
MIN_AVG_DAILY_VOLUME=1000000
